#!/bin/sh
#
# 熊猫记账 — Git pre-commit hook
# 质量门禁：检查是否通过了单元测试和质量检查
# 这是原生 hook 保护层，防止绕过 Claude Code 直接 git commit
#
# 安装：cp pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# 跳过：git commit --no-verify 或 git commit -n

QUALITY_GATE_DIR=".claude/quality-gate"
TEST_RESULT="$QUALITY_GATE_DIR/test-result.json"
QUALITY_RESULT="$QUALITY_GATE_DIR/quality-result.json"

RED='\e[0;31m'
GREEN='\e[0;32m'
YELLOW='\e[1;33m'
NC='\e[0m' # No Color

echo ""
echo "🔍 质量门禁检查中..."

# 检查标记文件是否存在
if [ ! -f "$TEST_RESULT" ] || [ ! -f "$QUALITY_RESULT" ]; then
    echo ""
    echo "${RED}══════════════════════════════════════════════════${NC}"
    echo "${RED}  ❌  提交被拒绝 — 质量门禁未通过${NC}"
    echo "${RED}══════════════════════════════════════════════════${NC}"
    echo ""
    echo "质量门禁标记文件不存在，请先运行："
    echo ""
    echo "  ${YELLOW}/gitcommit-agent${NC}"
    echo ""
    echo "这会自动运行测试和质量检查，通过后提交。"
    echo ""
    echo "如需紧急跳过（请确认已手动检查）："
    echo "  ${YELLOW}git commit --no-verify${NC}"
    echo ""
    exit 1
fi

# 读取 test-result.json
TEST_PASSED=$(grep -o '"passed":[^,}]*' "$TEST_RESULT" | head -1 | grep -o 'true\|false')

# 读取 quality-result.json
QUALITY_PASSED=$(grep -o '"passed":[^,}]*' "$QUALITY_RESULT" | head -1 | grep -o 'true\|false')
QUALITY_GRADE=$(grep -o '"grade":"[^"]*"' "$QUALITY_RESULT" | grep -o '[A-D]')

# 读取摘要信息
TEST_SUMMARY=$(grep -o '"summary":"[^"]*"' "$TEST_RESULT" | sed 's/"summary":"//;s/"//')
QUALITY_SUMMARY=$(grep -o '"summary":"[^"]*"' "$QUALITY_RESULT" | sed 's/"summary":"//;s/"//')

echo ""
echo "┌───────────────────────────────────────────┐"
echo "│  单元测试 : $( [ "$TEST_PASSED" = "true" ] && echo "${GREEN}通过 ✅${NC}" || echo "${RED}失败 ❌${NC}" )    │"
echo "│  质量检查 : $( [ "$QUALITY_PASSED" = "true" ] && echo "${GREEN}通过 ✅${NC}" || echo "${RED}失败 ❌${NC}" ) (Grade: $QUALITY_GRADE) │"
echo "└───────────────────────────────────────────┘"

if [ "$TEST_PASSED" = "true" ] && [ "$QUALITY_PASSED" = "true" ]; then
    echo ""
    echo "${GREEN}✅ 所有检查通过，允许提交！${NC}"
    echo ""
    exit 0
else
    echo ""
    echo "${RED}══════════════════════════════════════════════════${NC}"
    echo "${RED}  ❌  提交被拒绝 — 以下检查未通过：${NC}"
    echo "${RED}══════════════════════════════════════════════════${NC}"
    echo ""

    if [ "$TEST_PASSED" != "true" ]; then
        echo "  ${RED}✗${NC} 单元测试：$TEST_SUMMARY"
    fi
    if [ "$QUALITY_PASSED" != "true" ]; then
        echo "  ${RED}✗${NC} 质量检查：$QUALITY_SUMMARY"
    fi

    echo ""
    echo "请先修复问题，然后运行："
    echo "  ${YELLOW}/gitcommit-agent${NC}"
    echo ""
    echo "如需紧急跳过（请确认已手动检查）："
    echo "  ${YELLOW}git commit --no-verify${NC}"
    echo ""
    exit 1
fi
